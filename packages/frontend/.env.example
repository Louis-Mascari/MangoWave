# Spotify OAuth (required for Spotify integration)
VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id
VITE_SPOTIFY_REDIRECT_URI=http://localhost:5173
VITE_API_URL=https://your-api-gateway-url.amazonaws.com

# Spotify lock gate (optional — restricts Spotify connect to magic-link visitors)
VITE_LOCKED_MODE=false
VITE_UNLOCK_HASH=

# Observability (optional — omit to disable)
VITE_SENTRY_DSN=
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=
