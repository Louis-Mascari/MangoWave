{
  "$schema": "https://unpkg.com/knip@latest/schema.json",
  "ignoreBinaries": ["tsc"],
  "exclude": ["types"],
  "ignore": ["scripts/**", "infrastructure/lib/**"],
  "workspaces": {
    "packages/frontend": {
      "entry": ["e2e/**/*.spec.ts"],
      "project": ["src/**/*.{ts,tsx}", "e2e/**/*.ts"],
      "ignore": ["src/types/**/*.d.ts"],
      "ignoreDependencies": ["tailwindcss"]
    },
    "packages/butterchurn": {},
    "packages/butterchurn-presets": {},
    "packages/milkdrop-presets": {},
    "packages/milkdrop-textures": {},
    "packages/backend": {},
    "infrastructure": {
      "entry": ["bin/mangowave.ts"],
      "ignoreDependencies": ["esbuild", "ts-node"]
    }
  }
}
